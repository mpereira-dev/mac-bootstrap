{
  "homebrewPrefix": "/opt/homebrew",
  "defaultNode": "22",
  "defaultPython": "3.12",
  "profiles": {
    "core": {
      "description": "Shell baseline used by every workflow.",
      "defaultEnabled": true
    },
    "node": {
      "description": "Node.js runtime + bun via Volta.",
      "defaultEnabled": true
    },
    "python": {
      "description": "Python toolchain: uv (interpreters + packaging) and Poetry.",
      "defaultEnabled": true
    },
    "ai": {
      "description": "AI CLI providers (claude, codex, antigravity).",
      "defaultEnabled": false
    },
    "mobile": {
      "description": "Mobile development (Flutter, Android Studio, CocoaPods).",
      "defaultEnabled": false
    },
    "network": {
      "description": "Networking + remote access (Tailscale).",
      "defaultEnabled": false
    },
    "cloud": {
      "description": "Cloud tooling (AWS CLI + CDK).",
      "defaultEnabled": false
    }
  },
  "presets": {
    "scout": {
      "description": "Any machine: shell + Node + Python baseline.",
      "profiles": ["core", "node", "python"]
    },
    "ranger": {
      "description": "Cloud workstation: baseline + AWS tooling.",
      "profiles": ["core", "node", "python", "cloud"]
    },
    "falcon": {
      "description": "Connected workstation: baseline + AI + Tailscale.",
      "profiles": ["core", "node", "python", "ai", "network"]
    },
    "ace": {
      "description": "Mobile + AI rig: baseline + Flutter stack + AI CLIs.",
      "profiles": ["core", "node", "python", "ai", "mobile"]
    },
    "maverick": {
      "description": "Everything: every profile enabled.",
      "profiles": ["core", "node", "python", "ai", "mobile", "network", "cloud"]
    }
  },
  "formulae": [
    {
      "name": "git",
      "profile": "core",
      "why": "Source control baseline for all development."
    },
    {
      "name": "gh",
      "profile": "core",
      "why": "GitHub CLI for repository and issue workflows."
    },
    {
      "name": "jq",
      "profile": "core",
      "why": "JSON inspection and scripting."
    },
    {
      "name": "ripgrep",
      "profile": "core",
      "why": "Fast repository search."
    },
    {
      "name": "coreutils",
      "profile": "core",
      "why": "GNU-compatible shell utilities."
    },
    {
      "name": "tree",
      "profile": "core",
      "why": "Quick filesystem inspection."
    },
    {
      "name": "volta",
      "profile": "node",
      "why": "Pinned Node.js runtime management."
    },
    {
      "name": "oven-sh/bun/bun",
      "profile": "node",
      "why": "Fast JavaScript runtime + package manager."
    },
    {
      "name": "uv",
      "profile": "python",
      "command": "uv",
      "why": "Fast Python interpreter + project manager. Owns Python versions (replaces brew python / pyenv) and packaging."
    },
    {
      "name": "poetry",
      "profile": "python",
      "command": "poetry",
      "why": "Project/dependency manager for existing Poetry projects; coexists with uv during migration."
    },
    {
      "name": "cocoapods",
      "profile": "mobile",
      "why": "iOS dependency manager required by Flutter iOS builds."
    },
    {
      "name": "awscli",
      "profile": "cloud",
      "command": "aws",
      "why": "AWS CLI v2. Homebrew formula; replaces the standalone macOS .pkg install."
    },
    {
      "name": "aws-cdk",
      "profile": "cloud",
      "command": "cdk",
      "why": "AWS CDK toolkit. Homebrew formula; replaces an ad-hoc global npm install of aws-cdk."
    }
  ],
  "casks": [
    {
      "name": "claude-code",
      "profile": "ai",
      "command": "claude",
      "selfUpdate": ["claude", "update"],
      "why": "Claude Code CLI."
    },
    {
      "name": "codex",
      "profile": "ai",
      "command": "codex",
      "why": "OpenAI Codex CLI."
    },
    {
      "name": "antigravity-cli",
      "profile": "ai",
      "command": "antigravity",
      "why": "Antigravity CLI."
    },
    {
      "name": "android-studio",
      "profile": "mobile",
      "why": "Android IDE + SDK manager + bundled JDK used by Flutter and Gradle."
    },
    {
      "name": "flutter",
      "profile": "mobile",
      "why": "Flutter SDK for cross-platform mobile development."
    },
    {
      "name": "tailscale-app",
      "profile": "network",
      "why": "Mesh VPN providing private hostnames + HTTPS certs for laptop services."
    }
  ],
  "npmGlobals": []
}
