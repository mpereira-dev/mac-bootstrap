#!/usr/bin/env node
import { CommandRunner } from "../src/command-runner.js";
import { printHelp } from "../src/help.js";
import { ConsoleLogger } from "../src/logger.js";
import { migrate } from "../src/migrate.js";

function parseMigrateArgs(argv) {
  const options = {
    apply: false,
    home: process.env.HOME,
    manifestPath: undefined,
    tools: []
  };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === "--apply") {
      options.apply = true;
    } else if (arg === "--home") {
      index += 1;
      options.home = requireValue(arg, argv[index]);
    } else if (arg.startsWith("--home=")) {
      options.home = arg.slice("--home=".length);
    } else if (arg === "--packages") {
      index += 1;
      options.manifestPath = requireValue(arg, argv[index]);
    } else if (arg.startsWith("--packages=")) {
      options.manifestPath = arg.slice("--packages=".length);
    } else if (arg === "--help" || arg === "-h") {
      options.help = true;
      options.helpTopics = argv.slice(index + 1);
      break;
    } else if (arg.startsWith("-")) {
      throw new Error(`Unknown argument: ${arg}`);
    } else {
      options.tools.push(arg);
    }
  }

  return options;
}

function requireValue(flag, value) {
  if (!value) {
    throw new Error(`${flag} requires a value`);
  }
  return value;
}

const logger = new ConsoleLogger();
try {
  const options = parseMigrateArgs(process.argv.slice(2));
  if (options.help) {
    process.exit(printHelp("migrate", options.helpTopics));
  }
  const exitCode = await migrate({
    ...options,
    runner: new CommandRunner(),
    logger
  });
  process.exit(exitCode);
} catch (error) {
  logger.error(error.message);
  process.exit(1);
}
