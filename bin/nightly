#!/usr/bin/env node
import { parseArgs } from "../src/args.js";
import { CommandRunner } from "../src/command-runner.js";
import { nightly, nightlyHelp } from "../src/nightly.js";

try {
  const options = parseArgs(process.argv.slice(2));
  if (options.help) {
    console.log(nightlyHelp());
    process.exit(0);
  }
  const exitCode = await nightly({
    ...options,
    runner: new CommandRunner({ dryRun: options.dryRun }),
    logger: console,
    env: process.env
  });
  process.exit(exitCode);
} catch (error) {
  console.error(error.message);
  process.exit(1);
}
